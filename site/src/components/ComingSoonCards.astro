---
const stats = ['Pass Counts', 'Shots', 'Shots on Target', 'Assists'];
---

<div class="coming-soon-section">
  <h4>Advanced Stats</h4>
  <div class="coming-soon-grid">
    {stats.map((name) => (
      <div class="cs-card">
        <div class="cs-lock" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
          </svg>
        </div>
        <p class="cs-name">{name}</p>
        <span class="cs-badge">Coming Soon</span>
      </div>
    ))}
  </div>
</div>

<style>
  .coming-soon-section {
    margin-top: 32px;
  }

  .coming-soon-section h4 {
    font-size: 1rem;
    font-weight: 600;
    color: #1d1d1f;
    margin-bottom: 12px;
  }

  .coming-soon-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 16px;
  }

  .cs-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 24px 16px;
    background: #f5f5f7;
    border-radius: 12px;
    opacity: 0.55;
    text-align: center;
    min-height: 140px;
  }

  .cs-lock {
    color: #86868b;
    margin-bottom: 8px;
  }

  .cs-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: #1d1d1f;
    margin-bottom: 4px;
  }

  .cs-badge {
    font-size: 0.75rem;
    font-weight: 500;
    color: #86868b;
    background: #e5e5e7;
    padding: 2px 10px;
    border-radius: 10px;
  }
</style>
